# 应用配置
APP_NAME=OpenAdmin
APP_VERSION=1.0.0
APP_DEBUG=True

# 跨域配置
APP_CORS_ALLOW_ORIGINS=*
APP_CORS_ALLOW_CREDENTIALS=True
APP_CORS_ALLOW_METHODS=*
APP_CORS_ALLOW_HEADERS=*
APP_CORS_EXPOSE_HEADERS=*
APP_CORS_MAX_AGE=600

# 文档配置
APP_DOCS_ENABLE=True
APP_DOCS_TITLE=OpenAdmin 后台管理系统
APP_DOCS_DESCRIPTION=基于 FastAPI + Vue3 开发的开源后台管理系统，提供完整的用户管理、权限控制、数据管理等功能。
APP_DOCS_VERSION=1.0.0
APP_DOCS_CONTACT_NAME=sjzhao
APP_DOCS_CONTACT_EMAIL=1500492856@qq.com
APP_DOCS_URL=/docs
APP_REDOC_URL=/redoc

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=username
DB_PASSWORD=password
DB_NAME=openadmin
DB_CHARSET=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_DEBUG=True

# JWT 配置
AUTH_JWT_SECRET_KEY=secret-key
AUTH_JWT_REFRESH_SECRET_KEY=refresh-secret-key
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

AUTH_MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENCODING=utf-8
REDIS_DECODE_RESPONSES=True
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=10
REDIS_MAX_CONNECTIONS=50