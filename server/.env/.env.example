# 应用配置
APP_NAME=OpenAdmin
APP_VERSION=1.0.0
APP_DEBUG=True

# 跨域配置
APP_CORS_ALLOW_ORIGINS=*
APP_CORS_ALLOW_CREDENTIALS=True
APP_CORS_ALLOW_METHODS=*
APP_CORS_ALLOW_HEADERS=*
APP_CORS_EXPOSE_HEADERS=*
APP_CORS_MAX_AGE=600

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=username
DB_PASSWORD=password
DB_NAME=openadmin
DB_CHARSET=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_DEBUG=True