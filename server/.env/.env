# 应用配置
APP_NAME=OpenAdmin
APP_VERSION=1.0.0
APP_DEBUG=True

# CORS 跨域配置
APP_CORS_ALLOW_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:8081"]
APP_CORS_ALLOW_CREDENTIALS=False
APP_CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
APP_CORS_ALLOW_HEADERS=["Content-Type", "Authorization"]
APP_CORS_EXPOSE_HEADERS=["token"]
APP_CORS_MAX_AGE=86400

# 数据库配置
DB_CHARSET=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_DEBUG=True