# 应用配置
APP_NAME=OpenAdmin
APP_VERSION=1.0.0
APP_DEBUG=True

# 文档配置
APP_DOCS_ENABLE=True
APP_DOCS_TITLE=OpenAdmin 后台管理系统
APP_DOCS_DESCRIPTION=基于 FastAPI + Vue3 开发的开源后台管理系统，提供完整的用户管理、权限控制、数据管理等功能。
APP_DOCS_VERSION=1.0.0
APP_DOCS_CONTACT_NAME=sjzhao
APP_DOCS_CONTACT_EMAIL=1500492856@qq.com
APP_DOCS_URL=/docs
APP_REDOC_URL=/redoc

# CORS 跨域配置
APP_CORS_ALLOW_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:8081"]
APP_CORS_ALLOW_CREDENTIALS=False
APP_CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
APP_CORS_ALLOW_HEADERS=["Content-Type", "Authorization"]
APP_CORS_EXPOSE_HEADERS=["token"]
APP_CORS_MAX_AGE=86400

# 数据库配置
DB_CHARSET=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_DEBUG=True